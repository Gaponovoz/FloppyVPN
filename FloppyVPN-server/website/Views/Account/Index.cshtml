@namespace FloppyVPN
@using static FloppyVPN.Functions

@{
	ViewData["Title"] = "Account";

	string lang = GetCurrentLanguage(this);


}



<h4>
<span id="account-welcome-message">
	@Loc.Get("account-welcome-message", lang)
</span> "%%%user_login_masked_stars%%%"
</h4>

<br>

<span class="htext">
	<span class="htext">
		<img src="/account-view.png" />  
		<span class="highlight" id="account-message">
			@Loc.Get("account-message", lang)
		</span>
	</span>
</span>

<br>
<br>

<table>
	<tbody>
		<tr style="text-align: center;">
			<td><b id="column-your-login">@Loc.Get("column-your-login", lang)</b></td>
			<td><b id="column-paid-till">@Loc.Get("column-paid-till", lang)</b></td>
			<td><b id="column-days-left">@Loc.Get("column-days-left", lang)</b></td>
			<td><b id="column-registration-date">@Loc.Get("column-registration-date", lang)</b></td>
		</tr>
		<tr>
			<td>%%%user_login_masked_stars%%%</td>
			<td>%%%paid_till%%%</td>
			<td>%%%days_left%%%</td>
			<td>%%%date_registered%%%</td>
		</tr>
	</tbody>
</table>

<br>
<br>

<ul>
	<li>
		<span class="htext" id="account-tip1">
			@Loc.Get("account-tip1", lang)
		</span>
	</li>
	<li>
		<span class="htext" id="account-tip2">
			@Loc.Get("account-tip2", lang)
		</span>
	</li>
</ul>

<br>
<br>

<span class="htext"><img src="/account-addtime.png" />  
	<span class="highlight" id="topup-balance">
		@Loc.Get("topup-balance", lang)
	</span>
</span>

<br>
<br>

<table>
	<tbody>
		<tr style="text-align: center;">
			<td><b id="column-currency">@Loc.Get("column-currency", lang)</b></td>
			<td><b id="column-cost">@Loc.Get("column-cost", lang)</b></td>
			<td><b id="column-payment-link">@Loc.Get("column-payment-link", lang)</b></td>
		</tr>
		<tr>
			<td>Monero (XMR)</td>
			<td>0.007 XMR</td>
			<td>link</td>
		</tr>
		<tr>
			<td>RUR (Rouble)</td>
			<td>220 ₽</td>
			<td>link</td>
		</tr>
	</tbody>
</table>
