@namespace FloppyVPN
@using static FloppyVPN._Functions

@{
	string lang = GetCurrentLanguage(this);
	ViewData["Title"] = Loc.Get("login_title", lang);
}



<h3 id="login-page-heading"></h3>

<br>
<span class="htext">
	<span class="htext" id="login-field-caption">
		@Loc.Get("login-field-caption", lang)
	</span>

	<form>
		<input type="password" name="user_login">
		<button onclick="" id="login-button">
			<b>
				@Loc.Get("login-button", lang)
			</b>
		</button>
	</form>

	<br><br>

	<span class="htext" id="register-proposal">
		@Loc.Get("register-proposal", lang)
	</span>
</span>

<a href="/register" id="register-button"><button>
		@Loc.Get("register-button", lang)
</button></a>

